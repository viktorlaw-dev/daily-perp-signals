# Copy this file to .env and fill in your actual values.
# Never commit .env to Git.

# Bybit Testnet API credentials (read-only / market data permissions only)
BYBIT_API_KEY=your_bybit_testnet_api_key_here
BYBIT_API_SECRET=your_bybit_testnet_api_secret_here

# Telegram Bot credentials from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
